# ── bookstack-mcp backend configuration ──────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=dev                      # dev | test | prod

# ── Database ─────────────────────────────────────────────────────────
# Local dev: start Postgres with docker compose up postgres -d
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bookstack
DATABASE_ECHO=false

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM (Groq) ───────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
# Leave blank to use offline NullLLM (extractive fallback — no API key needed)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_S=30.0

# ── Embeddings ───────────────────────────────────────────────────────
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384

# ── Chunking ─────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ────────────────────────────────────────────────────────
TOP_K=5
RETRIEVAL_CONF_THRESHOLD=0.25
ANALYZER_CONF_THRESHOLD=0.55

# ── Guardrails ───────────────────────────────────────────────────────
MAX_QUERY_CHARS=2000
OUTPUT_VALIDATION_MAX_RETRIES=2

# ── Prompts ──────────────────────────────────────────────────────────
PROMPT_VERSION=v1

# ── Observability ────────────────────────────────────────────────────
# Leave blank to disable MLflow
MLFLOW_TRACKING_URI=
AUDIT_LOG_DIR=./audit
